# Required for persistent production data. Use a standard PostgreSQL URL.
DATABASE_URL=postgresql://user:password@host:5432/agent_cfo?sslmode=require

# Canonical HTTPS origin used by metadata, security checks, and deployment validation.
NEXT_PUBLIC_SITE_URL=https://your-app.example.com

# Used by scheduled sync endpoints and internal jobs. Generate at least 32 random characters.
INTERNAL_JOB_SECRET=replace-with-at-least-32-random-characters

# 32 random bytes, base64-encoded. Keep old keys available during planned rotations.
# Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key
SECRETS_ENCRYPTION_KEY_ID=v1
# Optional JSON object used only while rotating existing encrypted credentials.
SECRETS_ENCRYPTION_PREVIOUS_KEYS={}

# Default model for OpenAI BYOK report generation.
OPENAI_DEFAULT_MODEL=gpt-5.5
RATE_LIMIT_HASH_KEY=replace-with-at-least-32-random-characters

# OAuth 2.1 resource-server settings for the remote MCP endpoint.
MCP_PUBLIC_URL=https://your-app.example.com
MCP_OAUTH_ISSUER=https://your-authorization-server.example.com
MCP_OAUTH_JWKS_URL=https://your-authorization-server.example.com/.well-known/jwks.json
MCP_OAUTH_AUDIENCE=https://your-app.example.com/mcp
MCP_OAUTH_PRIVY_SUBJECT_CLAIM=privy_user_id
MCP_OAUTH_WORKSPACE_CLAIM=workspace_id
MCP_ALLOWED_ORIGINS=https://chatgpt.com,https://claude.ai

# Privy authentication. Configure Google and wallet login in the Privy dashboard.
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret
PRIVY_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
